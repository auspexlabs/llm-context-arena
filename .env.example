OPENROUTER_API_KEY=

# Curia MCP client (legacy ARENA_* names still accepted)
# CURIA_API_URL=http://127.0.0.1:8001
# CURIA_AGENT_ID=cursor
# CURIA_MCP_TRANSPORT=stdio
# CURIA_MCP_HOST=127.0.0.1
# CURIA_MCP_PORT=8010

# Arena squad preset: normal (5 free models) | freebee9 (9 free models)
# JSON files in backend/squads/ — also swappable from Settings panel
ARENA_SQUAD=normal

# LM Studio (only required when SEMANTIC_BACKEND=biencoder)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5

# Semantic retrieval (default: learned ColBERT — no LM Studio needed)
SEMANTIC_BACKEND=colbert
COLBERT_LEARNED=true
COLBERT_DEVICE=auto
# If torch fails with libcudnn/libnccl ImportError, repair CUDA wheels (GPU is fine):
#   uv sync --reinstall-package torch
# Temporary CPU/hash fallback only:
# COLBERT_DEVICE=cpu
# COLBERT_LEARNED=false

# Production retrieval topology (see docs/decision_log.md DEC-010/011)
QUERY_ROUTER=embedding
FUSION_MODE=rrf
GRAPH_MODE=append
RERANK_MODEL=jinaai/jina-reranker-v3
RERANK_ENABLED=true
RETRIEVE_CANDIDATES=50
RERANK_TOP_K=20
CONTEXT_CHUNK_CAP=60

# Indexing
INDEX_MANIFEST_PATH=data/index_manifest.json
# INDEX_INCLUDE_GLOBS=
# INDEX_EXCLUDE_GLOBS=
INDEX_INCLUDE_UNTRACKED=true